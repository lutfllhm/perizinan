# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Railway will inject MYSQL_URL automatically)
# Individual credentials are optional if using MYSQL_URL
# DB_HOST=mysql.railway.internal
# DB_USER=root
# DB_PASSWORD=your-database-password
# DB_NAME=railway
# DB_PORT=3306

# JWT Secret (Generate using: node scripts/generate-jwt-secret.js)
JWT_SECRET=your-jwt-secret-here

# Frontend URL for CORS
FRONTEND_URL=https://iwarelicanse.up.railway.app
